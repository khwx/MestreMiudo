# Environment variables for MestreMiudo

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-next-auth-secret-key-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini API
GOOGLEAI_API_KEY=your-gemini-api-key-here

# Pixabay API
PIXABAY_API_KEY=your-pixabay-api-key-here

# OpenRouter API
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Groq API
GROQ_API_KEY=your-groq-api-key-here

# Google Cloud Storage
GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name
GOOGLE_CLOUD_STORAGE_CREDENTIALS=your-credentials-path

# Recaptcha V3
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Number Verification
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email Templates
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@yourdomain.com

# Session Configuration
SESSION_MAX_AGE=86400
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true

# API Rate Limits
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_QUIZ=20

# CDN Configuration
CDN_URL=https://cdn.yourdomain.com
CDN_AWS_ACCESS_KEY_ID=your-aws-access-key
CDN_AWS_SECRET_ACCESS_KEY=your-aws-secret-key
CDN_AWS_REGION=us-east-1

# Image Optimization
IMAGE_OPTIMIZE_ENABLED=true
IMAGE_MAX_WIDTH=1920
IMAGE_JPEG_QUALITY=90
IMAGE_WEBP_ENABLED=true

# Cache Configuration
CACHE_REDIS_URL=redis://localhost:6379
CACHE_TTL_DAILY_CHALLENGE=3600
CACHE_TTL_LESSONS=86400

# Analytics
ANALYTICS_ID=GA_MEASUREMENT_ID
ANALYTICS_DOMAIN=yourdomain.com

# Feature Flags
ENABLE_STORY_CREATOR=true
ENABLE_QUIZ_GENERATOR=true
ENABLE_DIAGNOSTIC_TESTS=true
ENABLE_ACHIEVEMENTS=true

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_RETENTION_DAYS=30

# Security
XSS_PROTECTION_ENABLED=true
CSRF_PROTECTION_ENABLED=true
RATE_LIMITING_ENABLED=true

# Backup and Recovery
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION=30

# Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Site temporarily unavailable for maintenance

# Localization
DEFAULT_LANGUAGE=pt-PT
SUPPORTED_LANGUAGES=pt-PT,en,es,fr,de
RTL_LANGUAGES=[]

# Accessibility
ACCESSIBILITY_ENABLED=true
HIGH_CONTRAST_MODE=false
REDUCED_MOTION_MODE=false
SCREEN_READER_SUPPORT=true

# Parental Controls
PARENTAL_CONTROL_ENABLED=true
AGE_RESTRICTION=13

# Social Sharing
SOCIAL_SHARE_ENABLED=true
SOCIAL_FACEBOOK_APP_ID=your-facebook-app-id
SOCIAL_TWITTER_API_KEY=your-twitter-api-key
SOCIAL_INSTAGRAM_CLIENT_ID=your-instagram-client-id

# Payment Integration
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key
PAYPAL_CLIENT_ID=your-paypal-client-id

# Loyalty Program
LOYALTY_ENABLED=true
POINTS_PER_QUIZ=10
POINTS_PER_DAILY_CHALLENGE=50
POINTS_PER_FIRST_QUIZ=100
POINTS_PER_PERFECT_SCORE=50

# Community Features
FORUM_ENABLED=true
CHAT_ENABLED=true
USER_PROFILES_ENABLED=true
BADGES_ENABLED=true
